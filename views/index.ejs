<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/style.css">
    <title>WeatherMetrics | Real-Time Dashboard</title>
</head>
<body>    
    <video autoplay muted loop id="background-video">
        <source src="/public/images/<%= locals.weatherCondition || 'clouds' %>.mp4" type="video/mp4">
    </video>

    <div class="video-container">    
        <% if (locals.city) { %>
            <main class="weather-block">
                <h2>Today</h2>
                <h3 class="title-block">Local Meteorological Report</h3>
                <p class="location-name"><strong><%= city %></strong></p>
                
                <div class="current-weather-icon">
                    <img src="https://openweathermap.org/img/wn/<%= icon %>@2x.png" alt="Current weather: <%= weatherDesc %>">
                </div>
                
                <p class="temperature-display"><%= temperature %>° F</p>
            </main>

            <section class="weather-forecast-section">
                <div class="container">
                    <div id="forecast-wrapper">
                        <table class="weather-forecast-week">
                            <thead>
                                border-bottom
                                <tr>
                                    <% day.forEach(dayName => { %>
                                        <th><%= dayName %></th>
                                    <% }); %>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <% weekIcon.forEach((iconCode, index) => { %>
                                        <td>
                                            <img src="https://openweathermap.org/img/wn/<%= iconCode %>@2x.png" 
                                                 alt="Forecast for day <%= index + 1 %>">
                                        </td>
                                    <% }); %>
                                </tr>
                                <tr>
                                    <% temperatureWeekForecast.forEach(temp => { %>
                                        <td><%= temp %>° F</td>
                                    <% }); %>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <div class="navigation-controls">
                <a href="/" class="btn-link">
                    <button class="return-button">Search New Location</button>
                </a>
            </div>

        <% } else { %>
            <div class="intro-container">
                <header>
                    <h1 class="hero-title">WeatherMetrics Dashboard</h1>
                    <p class="hero-subtitle">Enter a 5-digit zipcode for hyper-local data.</p>
                </header>
                
                <div class="entry-form">
                    <form action="/submit" method="post">
                        <input type="text" 
                               id="zipcode-box" 
                               name="zipcode" 
                               placeholder="e.g. 90210" 
                               pattern="[0-9]{5}" 
                               title="Please enter a 5-digit ZIP code"
                               class="input-form" 
                               required>
                        <br>
                        <button type="submit" class="form-submit">Analyze Data</button>
                    </form>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>