<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <title>500 | System Failure</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .error-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            backdrop-filter: grayscale(1) blur(10px);
        }
        .glitch-text {
        color: #00ff41; 
        font-family: 'Courier New', monospace;
        text-transform: uppercase;
        letter-spacing: 4px;
        text-shadow: 0 0 8px rgba(0, 255, 65, 0.6); 
        }
        .error-card {
            background: rgba(0, 0, 0, 0.8); 
            border: 1px solid #00ff41;
            padding: 2rem;
            border-radius: 10px;
        }
    </style>

<body>
    <video autoplay muted loop playsinline id="background-video">
        <source src="/images/screen_glitch.mp4" type="video/mp4">
    </video>

    <div class="error-container">
        <div class="error-card">
            <h1 class="glitch-text">Critical System Anomaly</h1>
            <p style="color: #00ff41; font-family: monospace;">
                [ERROR_CODE: 500]<br>
                Meteorological Engine has stalled. <br>
                Attempting automated reboot...
            </p>
            <a href="/">
                <button class="return-button" style="background: #00ff41; color: black;">
                    Re-Initialize System
                </button>
            </a>
        </div>
    </div>
</body>